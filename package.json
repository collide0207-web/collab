{
  "name": "collide-collab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Collide real-time collaboration backend (Yjs CRDT sync server)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "lib0": "^0.2.98",
    "pg": "^8.13.1",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
