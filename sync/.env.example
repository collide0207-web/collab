# --- server ---
PORT=4000
NODE_ENV=development

# --- auth ---
# HS256 shared secret used by the Control Plane to sign JWTs (dev).
# MUST be byte-identical to the Java control plane's collide.jwt.secret.
# In production prefer RS256 with JWT_PUBLIC_KEY (PEM).
JWT_SECRET=collide_shared_dev_secret_change_in_production_0123456789
JWT_ALG=HS256
# JWT_PUBLIC_KEY=

# Set to "true" to allow unauthenticated connections in local dev only.
DEV_ALLOW_ANON=true

# --- persistence ---
# If unset, an in-memory store is used (dev/tests only — not durable).
DATABASE_URL=
PERSIST_DEBOUNCE_MS=2000

# --- scaling / pubsub ---
# If unset, an in-process pub/sub is used (single node only).
REDIS_URL=

# --- limits ---
MAX_MESSAGE_BYTES=1048576
AWARENESS_THROTTLE_MS=50
DOC_IDLE_EVICT_MS=60000
