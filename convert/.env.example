# Collide convert service. Copy to .env and adjust.

# Port the HTTP server listens on.
PORT=4500

# LibreOffice binary. `soffice` inside the Docker image; on macOS dev you can set
# this to the app binary, e.g.
# SOFFICE_BIN=/Applications/LibreOffice.app/Contents/MacOS/soffice
SOFFICE_BIN=soffice

# Max accepted upload (bytes). Defaults to 100 MB to match the frontend.
MAX_UPLOAD_BYTES=104857600

# Kill a conversion that runs longer than this (ms).
CONVERSION_TIMEOUT_MS=60000

# Comma-separated browser origins allowed to call this service.
CORS_ALLOWED_ORIGINS=http://localhost:5173
